# URL base da aplicação (ex: https://myapp.company.com)
APP_URL=

# Browser a usar: chrome (padrão) ou edge
BROWSER=edge

# Caminho para o chromedriver.exe (só necessário quando BROWSER=chrome)
# CHROMEDRIVER_PATH=C:\ferramentas\chromedriver.exe

# Atraso em ms entre ações — útil para debug visual (ex: 1000). 0 = velocidade normal.
SLOW_MO=0
